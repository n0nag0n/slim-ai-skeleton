{% extends "layout.twig" %}

{% block title %}500 Server Error{% endblock %}

{% block content %}
<div class="card" style="text-align:center">
    <h2>500</h2>
    <p>Something went wrong on our end.</p>
    {% if message %}<p><code>{{ message }}</code></p>{% endif %}
    <p><a href="/">Go home</a></p>
</div>
{% endblock %}
