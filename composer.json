{
    "name": "n0nag0n/slim-ai-skeleton",
    "description": "AI-friendly Slim 4 skeleton",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.15",
        "slim/psr7": "^1.8",
        "php-di/slim-bridge": "^3.4",
        "vlucas/phpdotenv": "^5.6",
        "doctrine/dbal": "^4.2",
        "tracy/tracy": "^2.10",
        "slim/twig-view": "^3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "squizlabs/php_codesniffer": "^4.0",
        "slevomat/coding-standard": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "cp -n .env.example .env || true"
        ],
        "start": "php -S localhost:8080 -t public",
        "test": "phpunit",
        "migrate": "php console migrate",
        "lint": "phpcs --standard=phpcs.xml.dist",
        "stan": "phpstan analyse --configuration=phpstan.neon.dist",
        "cs-fix": "phpcbf --standard=phpcs.xml.dist",
        "sync-ai-instructions": "php console sync-ai-instructions"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
