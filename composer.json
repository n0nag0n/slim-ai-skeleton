{
    "name": "n0nag0n/slim-ai-skeleton",
    "description": "AI-friendly Slim 4 skeleton",
    "type": "project",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.15",
        "slim/psr7": "^1.8",
        "php-di/slim-bridge": "^3.4",
        "vlucas/phpdotenv": "^5.6",
        "doctrine/dbal": "^4.2",
        "tracy/tracy": "^2.10",
        "slim/twig-view": "^3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public",
        "test": "phpunit",
        "migrate": "php migrate",
        "sync-ai-instructions": [
            "cp AGENTS.md CLAUDE.md",
            "cp AGENTS.md .github/copilot-instructions.md",
            "cp AGENTS.md GEMINI.md",
            "cp AGENTS.md .cursorrules",
            "cp AGENTS.md .windsurfrules",
            "cp AGENTS.md .continue/rules/instructions.md",
            "cp AGENTS.md cline_docs/CONTEXT.md",
            "echo 'AI configs synced from AGENTS.md'"
        ]
    }
}
