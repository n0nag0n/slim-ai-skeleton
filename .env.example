# Application environment: dev, staging, production
# Controls caching, error detail, and behavior
APP_ENV=dev

# When true: Tracy debug bar + full error pages in HTML
# When false: production-safe JSON error responses
DEBUG_MODE=true

# Database — SQLite (default, no server needed)
# DB_PATH is relative to the project root
DB_DRIVER=pdo_sqlite
DB_PATH=var/database.sqlite

# Database — MySQL / MariaDB (uncomment and adjust to use)
# When using Docker Compose, the host is the service name: db
# For local dev (no Docker), use 127.0.0.1
# DB_DRIVER=pdo_mysql
# DB_HOST=db
# DB_PORT=3306
# DB_NAME=app
# DB_USER=root
# DB_PASS=
# DB_CHARSET=utf8mb4

# Database — PostgreSQL (uncomment and adjust to use)
# When using Docker Compose, the host is the service name: db
# For local dev (no Docker), use 127.0.0.1
# DB_DRIVER=pdo_pgsql
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=app
# DB_USER=postgres
# DB_PASS=

# CSRF — comma-separated path prefixes to exclude from CSRF protection
# API routes are typically excluded since CSRF is a browser-based attack:
#   CSRF_EXCLUDED_PATHS=/api,/health
# Leave empty to protect all state-changing routes (default for HTML apps):
#   CSRF_EXCLUDED_PATHS=
CSRF_EXCLUDED_PATHS=/api,/health

# CORS — comma-separated list of allowed origins for API access
# Used by CorsMiddleware to set Access-Control-Allow-Origin
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:4200,http://127.0.0.1:8080
